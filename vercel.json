{
    "functions": {
        "api/proxy.js": {
            "memory": 128,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "/api/proxy?path=:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}